# Vultr Serverless Inference (claim validation, rerank, report agents)
VULTR_API_KEY=your_vultr_serverless_inference_key_here

# NVIDIA build.nvidia.com (Explainability Agent — nemotron-3-ultra-550b-a55b)
NVIDIA_API_KEY=your_nvidia_api_key_here

# --- Optional API hardening (recommended for any non-local deployment) ---
# Shared bearer token required on /api/run, /api/run/stream, /api/early-access.
# Leave unset for local demos (auth disabled).
# VANTAGE_API_TOKEN=choose_a_long_random_string

# Comma-separated allowed CORS origins (default: http://localhost:3000,http://127.0.0.1:3000)
# CORS_ORIGINS=https://your-frontend.example.com

# Per-IP rate limits (slowapi syntax)
# VANTAGE_RUN_RATE_LIMIT=6/minute
# VANTAGE_SIGNUP_RATE_LIMIT=5/minute
